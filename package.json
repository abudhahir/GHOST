{
  "name": "get-ghost",
  "version": "0.2.0",
  "description": "Fetch and install AI agents, skills, instructions and rules from any git repository",
  "author": "cleveloper",
  "license": "MIT",
  "homepage": "https://github.com/abudhahir/GHOST#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/abudhahir/GHOST.git"
  },
  "bugs": {
    "url": "https://github.com/abudhahir/GHOST/issues"
  },
  "keywords": [
    "agentic",
    "ai-agents",
    "custom-agents",
    "skills",
    "instructions",
    "rules",
    "claude",
    "llm",
    "npx"
  ],
  "type": "module",
  "bin": { "ghost": "./dist/index.js" },
  "main": "./dist/index.js",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "commander": "^12.0.0",
    "p-limit": "^5.0.0",
    "simple-git": "^3.25.0",
    "undici": "^6.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "nock": "^13.5.0",
    "tmp": "^0.2.3",
    "@types/tmp": "^0.2.6",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": { "node": ">=18.0.0" }
}
